---
import { Image } from "astro:assets";
import type { IStack } from "../../lib/models/model";

interface Props {
  key: string;
  index: number;
  name: string;
  description: string;
  stacks: IStack[];
  thumbnail: ImageMetadata;
}

const { key, index, name, description, stacks, thumbnail } = Astro.props;
---

<div
  class="card-parent group relative border-t-2 border-[color:var(--ink)] py-8 lg:py-10 cursor-pointer overflow-hidden"
  data-cursor-text={name}
  data-key={key}
>
  <div class="flex items-center gap-6 lg:gap-10">
    <span class="font-mono text-sm opacity-40 shrink-0"
      >{String(index).padStart(2, "0")}</span
    >

    <div class="flex-1 flex flex-col gap-2 relative z-10">
      <p
        class="card-name font-display text-3xl sm:text-4xl lg:text-6xl transition-transform duration-500 group-hover:translate-x-4"
      >
        {name}
      </p>
      <div class="flex items-center gap-4 font-mono text-xs uppercase tracking-widest opacity-60">
        <span>{description}</span>
        <span class="flex gap-2">
          {stacks.map((s) => <s.icon size={14} />)}
        </span>
      </div>
    </div>

    <div
      class="thumb-wrap hidden lg:block w-40 h-28 overflow-hidden border-2 border-[color:var(--ink)] opacity-0 -rotate-3 scale-95 transition-all duration-500 group-hover:opacity-100 group-hover:rotate-0 group-hover:scale-100"
    >
      <Image
        class="object-cover w-full h-full"
        src={thumbnail}
        alt={name}
        densities={[1.5, 2]}
      />
    </div>

    <span
      class="arrow font-display text-2xl lg:text-4xl transition-transform duration-500 group-hover:translate-x-2 group-hover:-translate-y-2"
      >&#8599;</span
    >
  </div>
</div>

<script>
  import { animatePageOut } from "@/lib/animation/animation";

  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll(
      ".card-parent"
    ) as NodeListOf<HTMLElement>;
    cards.forEach((card) => {
      const key = card.dataset.key;
      card.addEventListener("click", () => animatePageOut("/projects/" + key));
    });
  });
</script>

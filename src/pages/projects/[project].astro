---
import { projectContents } from "@/lib/contents/project-contents";
import Layout from "../../layouts/Layout.astro";
import Footer from "@/components/astro/Footer.astro";
import { Image } from "astro:assets";
import { FaGithub, FaGlobe } from "react-icons/fa6";
import { FaFileAlt } from "react-icons/fa";

export function getStaticPaths() {
  return [
    { params: { project: "travelohi" } },
    { params: { project: "noteki" } },
    { params: { project: "easywork" } },
    { params: { project: "sunshine" } },
    { params: { project: "cropwhisper" } },
    { params: { project: "recall" } },
    { params: { project: "sunshinefi" } },
    { params: { project: "tarzan" } },
    { params: { project: "the-adventure-of-tpa" } },
  ];
}

const { project } = Astro.params;

const projectDetails = projectContents[project];
---

<Layout title={projectDetails.name}>
  <div class="flex flex-col px-6 lg:px-12 pt-4 pb-8">
    <a
      href="/projects"
      id="back-link"
      data-cursor-icon=" "
      class="reveal font-mono text-xs uppercase tracking-widest opacity-60 hover:opacity-100 mb-8 inline-flex items-center gap-2 w-fit opacity-0"
    >
      &larr; All projects
    </a>

    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-10">
      <h1 class="reveal font-display text-5xl lg:text-8xl leading-[0.85] opacity-0">
        {projectDetails.name}
      </h1>
      <div class="reveal flex gap-6 font-mono text-xs uppercase tracking-widest">
        {
          projectDetails.docs && (
            <a
              href={projectDetails.docs}
              class="flex items-center gap-2 hover:text-[#ff3d1a] transition-colors"
            >
              <FaFileAlt data-cursor-text="Docs" size={16} /> Docs
            </a>
          )
        }
        {
          projectDetails.demo && (
            <a
              href={projectDetails.demo}
              class="flex items-center gap-2 hover:text-[#ff3d1a] transition-colors"
            >
              <FaGlobe data-cursor-text="Demo" size={16} /> Demo
            </a>
          )
        }
        <a
          href={projectDetails.githubRepo}
          class="flex items-center gap-2 hover:text-[#ff3d1a] transition-colors"
        >
          <FaGithub data-cursor-text="Repository" size={16} /> Code
        </a>
      </div>
    </div>

    <div class="reveal border-y-2 border-[color:var(--ink)] py-2 mb-10 opacity-0">
      <Image
        class="w-full aspect-video object-cover object-top"
        src={projectDetails.thumbnail}
        alt={projectDetails.name}
      />
    </div>

    <div class="reveal grid lg:grid-cols-[auto_1fr] gap-6 lg:gap-16 mb-16 opacity-0">
      <p class="font-mono text-xs uppercase tracking-widest opacity-60 shrink-0">
        {projectDetails.description ?? "Project"}
      </p>
      <div class="max-w-3xl">
        {
          projectDetails.explanation
            .split("~")
            .map((paragraph) => (
              <p class="text-base lg:text-lg leading-relaxed mb-5">
                {paragraph}
              </p>
            ))
        }
      </div>
    </div>

    {
      projectDetails.imageDetails && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
          {projectDetails.imageDetails.map((i) => (
            <Image
              class="lightbox-trigger border-2 border-[color:var(--ink)] aspect-video w-full object-cover cursor-pointer"
              src={i}
              alt={projectDetails.name}
              data-cursor-text="View"
            />
          ))}
        </div>
      )
    }

    <div
      id="lightbox-overlay"
      class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none bg-black/0"
    >
      <img
        id="lightbox-image"
        class="max-h-[85vh] max-w-[90vw] object-contain border-2 border-[color:var(--paper)] scale-90"
        src=""
        alt=""
      />
    </div>

    <Footer />
  </div>
</Layout>

<script>
  import gsap from "gsap";
  import { animatePageOut } from "@/lib/animation/animation";

  gsap.set(".reveal", { y: 30 });
  gsap.to(".reveal", {
    y: 0,
    opacity: 1,
    duration: 0.7,
    stagger: 0.08,
    ease: "power3.out",
  });

  document.getElementById("back-link")?.addEventListener("click", (e) => {
    e.preventDefault();
    animatePageOut("/projects");
  });

  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("lightbox-overlay");
    const lightboxImage = document.getElementById(
      "lightbox-image",
    ) as HTMLImageElement | null;
    const triggers = document.querySelectorAll(
      ".lightbox-trigger",
    ) as NodeListOf<HTMLImageElement>;

    if (!overlay || !lightboxImage) return;

    const openLightbox = (src: string, alt: string) => {
      lightboxImage.src = src;
      lightboxImage.alt = alt;
      overlay.classList.remove("pointer-events-none");

      gsap.to(overlay, {
        duration: 0.35,
        opacity: 1,
        backgroundColor: "rgba(0,0,0,0.85)",
        ease: "power2.out",
      });
      gsap.fromTo(
        lightboxImage,
        { scale: 0.9, opacity: 0 },
        { duration: 0.35, scale: 1, opacity: 1, ease: "power2.out" },
      );
    };

    const closeLightbox = () => {
      gsap.to(overlay, {
        duration: 0.3,
        opacity: 0,
        backgroundColor: "rgba(0,0,0,0)",
        ease: "power1.in",
        onComplete: () => {
          overlay.classList.add("pointer-events-none");
        },
      });
      gsap.to(lightboxImage, {
        duration: 0.3,
        scale: 0.9,
        opacity: 0,
        ease: "power1.in",
      });
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () =>
        openLightbox(trigger.src, trigger.alt),
      );
    });

    overlay.addEventListener("click", closeLightbox);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeLightbox();
    });
  });
</script>

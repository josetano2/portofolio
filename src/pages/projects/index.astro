---
import Card from "@/components/astro/Card.astro";
import Layout from "../../layouts/Layout.astro";
import { projectContents } from "@/lib/contents/project-contents";
import Footer from "@/components/astro/Footer.astro";

const entries = Object.entries(projectContents);
---

<Layout title="Projects — Jose Jonathan Tano">
  <div class="flex flex-col px-6 lg:px-12 pt-8 lg:pt-4 pb-8">
    <div class="flex items-end justify-between mb-10 lg:mb-16">
      <h1
        class="reveal font-display text-5xl lg:text-8xl leading-[0.85] opacity-0"
      >
        SELECTED<br />WORK
      </h1>
      <p class="reveal hidden lg:block font-mono text-xs uppercase tracking-widest opacity-0 mb-2">
        {entries.length} projects
      </p>
    </div>

    <div class="flex flex-col border-b-2 border-[color:var(--ink)]">
      {
        entries.map(([projectName, project], idx) => (
          <div class="card-row">
            <Card
              key={projectName}
              index={idx + 1}
              name={project.name}
              stacks={project.stacks}
              description={project.description}
              thumbnail={project.thumbnail}
            />
          </div>
        ))
      }
    </div>

    <Footer />
  </div>
</Layout>

<script>
  import gsap from "gsap";

  gsap.set(".reveal", { y: 30 });
  gsap.to(".reveal", {
    y: 0,
    opacity: 1,
    duration: 0.7,
    stagger: 0.1,
    ease: "power3.out",
  });

  gsap.set(".card-row", { y: 40, opacity: 0 });
  gsap.to(".card-row", {
    y: 0,
    opacity: 1,
    duration: 0.6,
    stagger: 0.08,
    delay: 0.2,
    ease: "power3.out",
  });
</script>

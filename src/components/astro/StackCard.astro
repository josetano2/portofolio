---
import type { IStack } from "../../lib/models/model";

interface Props {
  stack: IStack;
}

const { stack } = Astro.props;
---

<div
  class="stack-card group flex flex-col items-center justify-center gap-3 p-4 border-2 border-[color:var(--ink)] transition-colors duration-300 hover:bg-[#ff3d1a] hover:border-[#ff3d1a]"
>
  <div class="text-3xl transition-transform duration-300 group-hover:scale-110 group-hover:text-[color:var(--paper)]">
    <stack.icon />
  </div>
  <p class="font-mono text-[10px] uppercase tracking-widest opacity-70 text-center group-hover:opacity-100 group-hover:text-[color:var(--paper)]">
    {stack.name}
  </p>
</div>

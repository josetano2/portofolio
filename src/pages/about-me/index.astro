---
import Layout from "../../layouts/Layout.astro";
import me from "../../lib/images/AboutMe/me.png";
import {
  myself,
  experiences,
  achievements,
} from "@/lib/contents/project-contents";
import { techStacks } from "@/lib/contents/tech-stacks";
import StackCard from "@/components/astro/StackCard.astro";
import { Image } from "astro:assets";
import Footer from "@/components/astro/Footer.astro";
import type { IStack } from "@/lib/models/model";
---

<Layout title="About Me — Jose Jonathan Tano">
  <div class="flex flex-col px-6 lg:px-12 pt-8 lg:pt-4 pb-8">
    <div
      class="grid lg:grid-cols-[1fr_1.2fr] gap-10 lg:gap-16 items-start mb-20 lg:mb-28"
    >
      <div class="reveal opacity-0">
        <h1 class="font-display text-5xl lg:text-7xl leading-[0.85] mb-6">
          ABOUT<br />ME<span class="text-[#ff3d1a]">.</span>
        </h1>
        <p class="text-base lg:text-lg leading-relaxed max-w-md">
          {myself}
        </p>
      </div>

      <div class="reveal relative border-2 border-[color:var(--ink)] aspect-[4/5] w-full max-w-md ml-auto opacity-0">
        <Image
          class="object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-500"
          src={me}
          alt="Jose Jonathan Tano"
          data-cursor-text="Hello"
        />
      </div>
    </div>

    <div class="reveal mb-20 lg:mb-28 opacity-0">
      <div class="flex items-baseline justify-between border-b-2 border-[color:var(--ink)] pb-4 mb-8">
        <h2 class="font-display text-2xl lg:text-4xl">Tech Stack</h2>
        <span class="font-mono text-xs uppercase tracking-widest opacity-60"
          >{"//"} tools I reach for</span
        >
      </div>

      <div class="flex flex-col gap-10">
        {
          techStacks.map((category) => (
            <div class="space-y-4">
              <h3 class="font-mono text-xs uppercase tracking-widest opacity-60">
                {category.title}
              </h3>
              <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3">
                {category.stacks.map((stack: IStack) => (
                  <StackCard stack={stack} />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="reveal grid md:grid-cols-2 gap-10 lg:gap-16 mb-8 opacity-0">
      <div>
        <div class="flex items-baseline justify-between border-b-2 border-[color:var(--ink)] pb-4 mb-6">
          <h2 class="font-display text-2xl lg:text-4xl">Achievements</h2>
        </div>
        <div class="flex flex-col">
          {
            achievements.map((achievement, idx) => (
              <div class="flex justify-between items-baseline gap-4 py-4 border-b border-[color:var(--ink)]/20 last:border-0">
                <span class="font-mono text-xs opacity-40 shrink-0">
                  {String(idx + 1).padStart(2, "0")}
                </span>
                <p class="text-sm lg:text-base flex-1">{achievement.name}</p>
                <span class="font-mono text-xs opacity-60 whitespace-nowrap">
                  {achievement.year}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <div class="flex items-baseline justify-between border-b-2 border-[color:var(--ink)] pb-4 mb-6">
          <h2 class="font-display text-2xl lg:text-4xl">Experience</h2>
        </div>
        <div class="flex flex-col">
          {
            experiences.map((experience, idx) => (
              <div class="flex justify-between items-baseline gap-4 py-4 border-b border-[color:var(--ink)]/20 last:border-0">
                <span class="font-mono text-xs opacity-40 shrink-0">
                  {String(idx + 1).padStart(2, "0")}
                </span>
                <p class="text-sm lg:text-base flex-1">{experience.name}</p>
                <span class="font-mono text-xs opacity-60 whitespace-nowrap">
                  {experience.year}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  import gsap from "gsap";

  gsap.set(".reveal", { y: 40 });
  gsap.to(".reveal", {
    y: 0,
    opacity: 1,
    duration: 0.8,
    stagger: 0.15,
    ease: "power3.out",
  });
</script>

---
import { projectContents } from "@/lib/contents/project-contents";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { FaGithub, FaGlobe } from "react-icons/fa6";
import { FaFileAlt } from "react-icons/fa";

export function getStaticPaths() {
  return [
    { params: { project: "travelohi" } },
    { params: { project: "easywork" } },
    { params: { project: "sunshine" } },
    { params: { project: "recall" } },
    { params: { project: "linkasa" } },
    { params: { project: "sunshinefi" } },
    { params: { project: "tarzan" } },
    { params: { project: "the-adventure-of-tpa" } },
    { params: { project: "janidb" } },
    { params: { project: "animob" } },
  ];
}

const { project } = Astro.params;

const projectDetails = projectContents[project];
---

<Layout title={projectDetails.name}>
  <div class="flex flex-col pt-4 lg:pt-0 justify-center items-center">
    <div
      class="flex flex-col h-full sm:p-4 lg:p-8 gap-6 w-full lg:w-3/4 justify-center items-center"
    >
      <div class="flex gap-6 justify-center">
        <Image
          class="border-2 border-slate-800 dark:border-slate-300 object-cover"
          src={projectDetails.thumbnail}
          alt={projectDetails.name}
        />
      </div>
      <div class="flex flex-col justify-center gap-3">
        <div class="flex items-center justify-between gap-6">
          <p
            class="text-2xl lg:text-3xl 2xl:text-4xl font-bold text-slate-900 dark:text-white"
          >
            {`> ${projectDetails.name}`}
          </p>
          <div class="flex gap-6 text-slate-700 dark:text-slate-300">
            {
              projectDetails.docs && (
                <a
                  href={projectDetails.docs}
                  class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >
                  <FaFileAlt
                    className="cursor-pointer"
                    size={25}
                    data-cursor-text="Docs"
                  />
                </a>
              )
            }
            {
              projectDetails.demo && (
                <a
                  href={projectDetails.demo}
                  class="hover:text-slate-900 dark:hover:text-white transition-colors"
                >
                  <FaGlobe
                    className="cursor-pointer"
                    size={25}
                    data-cursor-text="Demo"
                  />
                </a>
              )
            }
            <a
              href={projectDetails.githubRepo}
              class="hover:text-slate-900 dark:hover:text-white transition-colors"
            >
              <FaGithub
                className="cursor-pointer"
                size={25}
                data-cursor-text="Repository"
              />
            </a>
          </div>
        </div>
        <div>
          {
            projectDetails.explanation
              .split("~")
              .map((paragraph) => (
                <p class="text-justify text-lg mb-4 text-slate-700 dark:text-slate-300">
                  {paragraph}
                </p>
              ))
          }
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {
          projectDetails &&
            projectDetails.imageDetails &&
            projectDetails.imageDetails.map((i) => (
              <Image
                class="lightbox-trigger border-2 border-slate-800 dark:border-slate-300 aspect-video w-full object-cover cursor-pointer"
                src={i}
                alt={projectDetails.name}
                data-cursor-text="View"
              />
            ))
        }
      </div>

      <div
        id="lightbox-overlay"
        class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none bg-black/0"
      >
        <img
          id="lightbox-image"
          class="max-h-[85vh] max-w-[90vw] object-contain border-2 border-slate-300 scale-90"
          src=""
          alt=""
        />
      </div>
    </div>
  </div></Layout
>

<script>
  import gsap from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("lightbox-overlay");
    const lightboxImage = document.getElementById(
      "lightbox-image",
    ) as HTMLImageElement | null;
    const triggers = document.querySelectorAll(
      ".lightbox-trigger",
    ) as NodeListOf<HTMLImageElement>;

    if (!overlay || !lightboxImage) return;

    const openLightbox = (src: string, alt: string) => {
      lightboxImage.src = src;
      lightboxImage.alt = alt;
      overlay.classList.remove("pointer-events-none");

      gsap.to(overlay, {
        duration: 0.35,
        opacity: 1,
        backgroundColor: "rgba(0,0,0,0.85)",
        ease: "power2.out",
      });
      gsap.fromTo(
        lightboxImage,
        { scale: 0.9, opacity: 0 },
        { duration: 0.35, scale: 1, opacity: 1, ease: "power2.out" },
      );
    };

    const closeLightbox = () => {
      gsap.to(overlay, {
        duration: 0.3,
        opacity: 0,
        backgroundColor: "rgba(0,0,0,0)",
        ease: "power1.in",
        onComplete: () => {
          overlay.classList.add("pointer-events-none");
        },
      });
      gsap.to(lightboxImage, {
        duration: 0.3,
        scale: 0.9,
        opacity: 0,
        ease: "power1.in",
      });
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () =>
        openLightbox(trigger.src, trigger.alt),
      );
    });

    overlay.addEventListener("click", closeLightbox);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeLightbox();
    });
  });
</script>
